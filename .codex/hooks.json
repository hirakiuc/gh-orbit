{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/oraios/serena@v1.5.1 serena-hooks remind --client=codex"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/oraios/serena@v1.5.1 serena-hooks activate --client=codex"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/oraios/serena@v1.5.1 serena-hooks cleanup --client=codex"
          }
        ]
      }
    ]
  }
}
