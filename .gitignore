# Ignore all of .agents by default
.agents/*

# Allow only specific persistent skills and workflows
!.agents/skills/
.agents/skills/*
!.agents/skills/gh-extension-expert/
.agents/skills/gh-extension-expert/*
!.agents/skills/gh-extension-expert/SKILL.md
!.agents/skills/gh-extension-expert/references/
.agents/skills/gh-extension-expert/references/*
!.agents/skills/gh-extension-expert/references/*.md

!.agents/skills/worker-role/
.agents/skills/worker-role/*
!.agents/skills/worker-role/SKILL.md

!.agents/skills/reviewer-role/
.agents/skills/reviewer-role/*
!.agents/skills/reviewer-role/SKILL.md

#!.agents/skills/zenoh-expert/
#.agents/skills/zenoh-expert/*
#!.agents/skills/zenoh-expert/SKILL.md

!.agents/workflows/
.agents/workflows/*.md
!.agents/workflows/strategy-review/
!.agents/workflows/strategy-review/*.md

# Explicitly ignore proposals and other transient agent files
.agents/proposals/
.agents/implementation_plan.md
.agents/issue.md
.agents/proposal.md
.agents/feedback.md

# End of .agents rules

# Temporary directory
/tmp/*
!/tmp/.gitkeep

# Ignore serena files
.serena/

# Created by https://www.toptal.com/developers/gitignore/api/vim,go
# Edit at https://www.toptal.com/developers/gitignore?templates=vim,go

### Go ###
# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

### Vim ###
.nvimlog
# Swap
[._]*.s[a-v][a-z]
!*.svg  # comment out if you don't need vector files
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Session
Session.vim
Sessionx.vim

# Temporary
.netrwhist
*~
# Auto-generated tag files
tags
# Persistent undo
[._]*.un~

# End of https://www.toptal.com/developers/gitignore/api/vim,go
bin/

# SQLite
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Logs
*.log
logs/
coverage.out
coverage.html
artifacts/
/bin/gh-orbit
